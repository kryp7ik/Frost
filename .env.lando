APP_NAME=Frost
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://frost.lndo.site

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=database
DB_PORT=3306
DB_DATABASE=frost
DB_USERNAME=frost
DB_PASSWORD=frost

BROADCAST_DRIVER=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
